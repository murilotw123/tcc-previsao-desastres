# ===== Dados grandes — NÃO versionados (ficam no Google Drive) =====
# Brutos (CSV do INMET de 2,8 GB, Atlas, etc.)
data/raw/*
!data/raw/.gitkeep

# Versões antigas / superadas do pipeline
data/archive/*
!data/archive/.gitkeep

# Parquets imputados por estação (centenas de arquivos, ~700 MB no total)
data/processed/imputed_by_station_final/
data/processed/imputed_by_station_excluidas_cronicas/
*.parquet

# Os CSVs pequenos são versionados de propósito:
#   data/metadata/  (metadados das estações, ponte estação-município, exclusões)
#   data/processed/y_eventos_*.csv  (tabela-alvo Y)
#   reports/        (relatórios de imputação e validação)

# ===== Modelos treinados =====
models/*
!models/.gitkeep
*.pkl
*.joblib
*.h5
*.pt

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg

# ===== Ambientes virtuais =====
venv/
env/
ENV/
.venv/
.env

# ===== Jupyter Notebook =====
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ===== Editores / IDEs =====
.vscode/
.idea/
*.swp
*.swo

# ===== Sistema operacional =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Google Drive =====
*.gsheet
*.gdoc

# ===== Outros =====
*.log
.cache/
